{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lian Li Linux",
  "version": "0.1.0",
  "identifier": "com.sgtaziz.lianlilinux",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lian Li Linux",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "dialog": null,
    "shell": {
      "open": true
    }
  }
}
